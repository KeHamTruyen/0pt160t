GEMINI_API_KEY=your_gemini_api_key_here

# Optional tuning
SUPPORT_BASE_URL=https://support.optisigns.com
ARTICLE_LOCALE=en-us
MAX_ARTICLES=30
REQUIRED_ARTICLE_IDS=360051014713
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FILE_SEARCH_EMBEDDING_MODEL=models/gemini-embedding-001
FILE_SEARCH_STORE_NAME=
FILE_SEARCH_STORE_DISPLAY_NAME=optibot-support-docs

# Output/cache paths
DOCS_DIR=data/docs
STATE_PATH=data/state/articles.json
UPLOAD_LOG_PATH=data/logs/last_run.json
